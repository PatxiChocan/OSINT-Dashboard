<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>OSINT Arsenal</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #f5f6f8;
    --bg2: #ffffff;
    --bg3: #f0f1f4;
    --border: #e2e4e9;
    --text: #1a1d23;
    --text2: #5a6070;
    --text3: #9099a8;
    --accent: #3b6fe0;
    --accent2: #2952b3;
    --green: #1a7f4b;
    --green-bg: #edf7f2;
    --amber: #b45309;
    --amber-bg: #fef3e2;
    --red: #c0392b;
    --red-bg: #fdecea;
    --blue-bg: #eef3fd;
    --sidebar: #1e2130;
    --sidebar-text: #a8b0c0;
    --sidebar-active: #ffffff;
    --sidebar-hover: #2a2f45;
    --shadow: 0 1px 4px rgba(0,0,0,0.08);
    --shadow2: 0 4px 16px rgba(0,0,0,0.10);
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background:var(--bg); color:var(--text); font-family:'Inter',sans-serif; min-height:100vh; font-size:14px; }

  /* LAYOUT */
  .layout { display:grid; grid-template-columns:240px 1fr; min-height:100vh; }

  /* SIDEBAR */
  .sidebar { background:var(--sidebar); display:flex; flex-direction:column; position:sticky; top:0; height:100vh; overflow-y:auto; }
  .sidebar-logo { padding:20px 20px 16px; border-bottom:1px solid rgba(255,255,255,0.07); }
  .logo-title { font-size:1rem; font-weight:700; color:#fff; letter-spacing:.5px; }
  .logo-sub { font-size:.68rem; color:var(--sidebar-text); margin-top:2px; letter-spacing:1px; text-transform:uppercase; }
  .sidebar-section { padding:16px 12px 4px; font-size:.6rem; letter-spacing:2px; text-transform:uppercase; color:rgba(255,255,255,0.25); font-weight:600; }
  .nav-btn { display:flex; align-items:center; gap:10px; width:100%; padding:9px 12px; background:none; border:none; border-radius:8px; color:var(--sidebar-text); font-family:'Inter',sans-serif; font-size:.82rem; cursor:pointer; text-align:left; transition:all .15s; margin-bottom:2px; }
  .nav-btn:hover { background:var(--sidebar-hover); color:#fff; }
  .nav-btn.active { background:rgba(59,111,224,0.2); color:var(--sidebar-active); font-weight:500; }
  .nav-btn .icon { font-size:1rem; width:20px; text-align:center; flex-shrink:0; }
  .nav-divider { height:1px; background:rgba(255,255,255,0.07); margin:8px 12px; }
  .sidebar-status { margin-top:auto; padding:14px 16px; border-top:1px solid rgba(255,255,255,0.07); font-size:.68rem; color:rgba(255,255,255,0.3); }
  .status-dot { width:6px; height:6px; border-radius:50%; background:#22c55e; display:inline-block; margin-right:5px; animation:pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }

  /* MAIN */
  .main { display:flex; flex-direction:column; min-height:100vh; }

  /* TOPBAR */
  .topbar { background:var(--bg2); border-bottom:1px solid var(--border); padding:12px 24px; display:flex; align-items:center; gap:12px; position:sticky; top:0; z-index:50; box-shadow:var(--shadow); }
  .topbar-label { font-size:.72rem; color:var(--text3); white-space:nowrap; font-weight:500; }
  .target-input { flex:1; max-width:360px; background:var(--bg3); border:1.5px solid var(--border); border-radius:8px; padding:8px 14px; font-family:'Inter',sans-serif; font-size:.85rem; color:var(--text); outline:none; transition:border-color .15s; }
  .target-input:focus { border-color:var(--accent); background:#fff; }
  .target-input::placeholder { color:var(--text3); }
  .topbar-right { margin-left:auto; font-size:.72rem; color:var(--text3); display:flex; gap:16px; align-items:center; }
  .target-chip { background:var(--blue-bg); color:var(--accent); border:1px solid #c7d8f8; border-radius:20px; padding:3px 10px; font-size:.7rem; font-weight:500; display:none; }

  /* CONTENT */
  .content { flex:1; padding:24px; overflow-y:auto; }

  /* PANEL */
  .panel { display:none; }
  .panel.active { display:block; }

  /* PAGE HEADER */
  .page-header { margin-bottom:20px; }
  .page-title { font-size:1.3rem; font-weight:700; color:var(--text); margin-bottom:4px; display:flex; align-items:center; gap:10px; }
  .page-desc { font-size:.82rem; color:var(--text2); line-height:1.6; }

  /* TAGS */
  .tag { display:inline-block; font-size:.62rem; padding:2px 8px; border-radius:20px; font-weight:600; letter-spacing:.3px; margin-right:4px; }
  .tag-mit { background:#e8f5e9; color:#2e7d32; }
  .tag-apache { background:#e3f2fd; color:#1565c0; }
  .tag-gpl { background:#fff8e1; color:#f57f17; }
  .tag-npsl { background:#fce4ec; color:#c62828; }

  /* SUBTOOL GRID */
  .subtool-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:10px; margin-bottom:20px; }
  .subtool-card { background:var(--bg2); border:1.5px solid var(--border); border-radius:10px; padding:14px; cursor:pointer; transition:all .15s; }
  .subtool-card:hover { border-color:#c7d8f8; box-shadow:var(--shadow2); transform:translateY(-1px); }
  .subtool-card.selected { border-color:var(--accent); background:var(--blue-bg); box-shadow:0 0 0 3px rgba(59,111,224,0.1); }
  .sc-top { display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:6px; }
  .sc-name { font-size:.82rem; font-weight:600; color:var(--text); }
  .sc-func { font-size:.72rem; color:var(--text2); line-height:1.5; }
  .alert-badge { font-size:.58rem; font-weight:700; padding:2px 7px; border-radius:20px; white-space:nowrap; }
  .al-none { background:var(--green-bg); color:var(--green); }
  .al-low { background:#e3f2fd; color:#1565c0; }
  .al-med { background:var(--amber-bg); color:var(--amber); }
  .al-high { background:var(--red-bg); color:var(--red); }

  /* CMD PREVIEW */
  .cmd-preview { background:#1e2130; border-radius:10px; padding:14px 16px; margin-bottom:16px; display:none; }
  .cmd-preview.show { display:block; }
  .cmd-label { font-size:.62rem; color:rgba(255,255,255,0.35); text-transform:uppercase; letter-spacing:1.5px; margin-bottom:8px; font-weight:600; }
  .cmd-code { font-family:'JetBrains Mono',monospace; font-size:.8rem; color:#a8d8a8; line-height:1.6; word-break:break-all; }
  .cmd-prompt { color:rgba(255,255,255,0.3); }

  /* ACTIONS ROW */
  .actions-row { display:flex; gap:10px; margin-bottom:20px; flex-wrap:wrap; align-items:center; }
  .extra-input { flex:1; min-width:200px; background:var(--bg2); border:1.5px solid var(--border); border-radius:8px; padding:8px 14px; font-family:'Inter',sans-serif; font-size:.82rem; color:var(--text); outline:none; transition:border-color .15s; }
  .extra-input:focus { border-color:var(--accent); }
  .extra-input::placeholder { color:var(--text3); }
  .run-btn { background:var(--accent); border:none; color:#fff; font-family:'Inter',sans-serif; font-size:.82rem; font-weight:600; padding:9px 22px; border-radius:8px; cursor:pointer; transition:all .15s; display:flex; align-items:center; gap:6px; }
  .run-btn:hover { background:var(--accent2); box-shadow:0 4px 12px rgba(59,111,224,0.3); }
  .run-btn:disabled { opacity:.4; cursor:not-allowed; }
  .stop-btn { background:#fff; border:1.5px solid var(--red); color:var(--red); font-family:'Inter',sans-serif; font-size:.82rem; font-weight:600; padding:9px 22px; border-radius:8px; cursor:pointer; transition:all .15s; display:none; }
  .stop-btn:hover { background:var(--red); color:#fff; }

  /* OUTPUT */
  .output-section { background:var(--bg2); border:1.5px solid var(--border); border-radius:12px; overflow:hidden; }
  .output-header { padding:12px 16px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; background:var(--bg3); }
  .output-title { font-size:.78rem; font-weight:600; color:var(--text); }
  .output-actions { display:flex; gap:8px; }
  .clr-btn { background:none; border:1px solid var(--border); color:var(--text2); font-family:'Inter',sans-serif; font-size:.7rem; padding:4px 10px; border-radius:6px; cursor:pointer; transition:all .15s; }
  .clr-btn:hover { border-color:var(--red); color:var(--red); }

  /* RESULTS */
  .results-area { padding:16px; min-height:200px; }
  .result-group { margin-bottom:20px; }
  .result-group:last-child { margin-bottom:0; }
  .rg-title { font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:var(--text3); margin-bottom:10px; padding-bottom:6px; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:6px; }
  .rg-count { background:var(--accent); color:#fff; font-size:.6rem; padding:1px 7px; border-radius:20px; font-weight:700; }
  .result-items { display:flex; flex-direction:column; gap:4px; }
  .result-item { background:var(--bg3); border-radius:6px; padding:8px 12px; font-family:'JetBrains Mono',monospace; font-size:.76rem; color:var(--text); display:flex; align-items:center; gap:8px; word-break:break-all; }
  .result-item .ri-icon { font-size:.85rem; flex-shrink:0; }
  .result-item.email { border-left:3px solid var(--accent); }
  .result-item.host { border-left:3px solid var(--green); }
  .result-item.ip { border-left:3px solid var(--amber); }
  .result-item.url { border-left:3px solid #7c3aed; }
  .result-item.generic { border-left:3px solid var(--border); }

  /* RAW OUTPUT */
  .raw-output { font-family:'JetBrains Mono',monospace; font-size:.73rem; color:var(--text2); line-height:1.8; white-space:pre-wrap; word-break:break-all; padding:16px; min-height:200px; max-height:500px; overflow-y:auto; }
  .raw-output::-webkit-scrollbar { width:4px; }
  .raw-output::-webkit-scrollbar-thumb { background:var(--border); border-radius:4px; }

  /* OUTPUT TABS */
  .out-tabs { display:flex; gap:2px; padding:0 16px; border-bottom:1px solid var(--border); background:var(--bg2); }
  .out-tab { background:none; border:none; border-bottom:2px solid transparent; color:var(--text3); font-family:'Inter',sans-serif; font-size:.75rem; font-weight:500; padding:10px 14px; cursor:pointer; transition:all .15s; margin-bottom:-1px; }
  .out-tab:hover { color:var(--text); }
  .out-tab.active { color:var(--accent); border-bottom-color:var(--accent); }
  .out-tab-content { display:none; }
  .out-tab-content.active { display:block; }

  /* STATUS BAR */
  .status-bar { padding:10px 16px; border-top:1px solid var(--border); display:flex; align-items:center; gap:8px; font-size:.7rem; color:var(--text3); background:var(--bg3); }
  .status-running { color:#f59e0b; display:none; align-items:center; gap:6px; }
  .spinner { width:12px; height:12px; border:2px solid #f59e0b; border-top-color:transparent; border-radius:50%; animation:spin .7s linear infinite; }
  @keyframes spin { to{transform:rotate(360deg)} }
  .status-done { color:var(--green); display:none; }

  /* HOME */
  .home-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:14px; margin-top:20px; }
  .home-card { background:var(--bg2); border:1.5px solid var(--border); border-radius:12px; padding:20px; cursor:pointer; transition:all .15s; }
  .home-card:hover { border-color:#c7d8f8; box-shadow:var(--shadow2); transform:translateY(-2px); }
  .home-card-icon { font-size:1.8rem; margin-bottom:10px; }
  .home-card-name { font-size:.9rem; font-weight:700; color:var(--text); margin-bottom:4px; }
  .home-card-desc { font-size:.74rem; color:var(--text2); line-height:1.5; }
  .home-card-tag { margin-top:10px; }
  .stats-row { display:grid; grid-template-columns:repeat(auto-fit,minmax(140px,1fr)); gap:12px; margin-bottom:24px; }
  .stat-card { background:var(--bg2); border:1.5px solid var(--border); border-radius:10px; padding:16px; }
  .stat-val { font-size:1.5rem; font-weight:700; color:var(--accent); }
  .stat-label { font-size:.7rem; color:var(--text3); margin-top:2px; font-weight:500; }
</style>
</head>
<body>

<div class="layout">
  <!-- SIDEBAR -->
  <nav class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-title">OSINT Arsenal</div>
      <div class="logo-sub">Red Team Dashboard</div>
    </div>

    <div class="sidebar-section">Arsenal</div>
    <button class="nav-btn active" onclick="show('home',this)"><span class="icon">⌂</span>Overview</button>

    <div class="nav-divider"></div>
    <div class="sidebar-section">Herramientas</div>
    <button class="nav-btn" onclick="show('discover',this)"><span class="icon">🔍</span>Discover</button>
    <button class="nav-btn" onclick="show('amass',this)"><span class="icon">🌐</span>Amass</button>
    <button class="nav-btn" onclick="show('katana',this)"><span class="icon">🕷</span>Katana</button>
    <button class="nav-btn" onclick="show('gitleaks',this)"><span class="icon">🔑</span>GitLeaks</button>
    <button class="nav-btn" onclick="show('wayback',this)"><span class="icon">🕰</span>Wayback DL</button>
    <button class="nav-btn" onclick="show('spiderfoot',this)"><span class="icon">🕸</span>SpiderFoot</button>

    <div class="sidebar-status">
      <span class="status-dot"></span>Kali Linux · localhost:5000
    </div>
  </nav>

  <!-- MAIN -->
  <div class="main">
    <!-- TOPBAR -->
    <div class="topbar">
      <span class="topbar-label">🎯 Objetivo</span>
      <input class="target-input" id="targetInput" placeholder="ejemplo.com" oninput="updateTarget(this.value)">
      <div class="topbar-right">
        <span class="target-chip" id="targetChip"></span>
        <span id="clock" style="font-size:.72rem;color:var(--text3);"></span>
      </div>
    </div>

    <!-- CONTENT -->
    <div class="content">

      <!-- HOME -->
      <div class="panel active" id="panel-home">
        <div class="page-header">
          <div class="page-title">👋 Bienvenido</div>
          <div class="page-desc">Introduce el dominio objetivo arriba y selecciona una herramienta para empezar.</div>
        </div>
        <div class="stats-row">
          <div class="stat-card"><div class="stat-val">6</div><div class="stat-label">Herramientas</div></div>
          <div class="stat-card"><div class="stat-val">40+</div><div class="stat-label">Subherramientas</div></div>
          <div class="stat-card"><div class="stat-val">100%</div><div class="stat-label">Open Source</div></div>
          <div class="stat-card"><div class="stat-val">Local</div><div class="stat-label">Sin datos externos</div></div>
        </div>
        <div class="home-grid">
          <div class="home-card" onclick="show('discover',null)">
            <div class="home-card-icon">🔍</div>
            <div class="home-card-name">Discover</div>
            <div class="home-card-desc">Framework orquestador. theHarvester, Nmap, DNSRecon, Nikto y más.</div>
            <div class="home-card-tag"><span class="tag tag-mit">MIT</span></div>
          </div>
          <div class="home-card" onclick="show('amass',null)">
            <div class="home-card-icon">🌐</div>
            <div class="home-card-name">Amass</div>
            <div class="home-card-desc">Enumeración de subdominios con +55 fuentes y tracking histórico.</div>
            <div class="home-card-tag"><span class="tag tag-apache">Apache 2.0</span></div>
          </div>
          <div class="home-card" onclick="show('katana',null)">
            <div class="home-card-icon">🕷</div>
            <div class="home-card-name">Katana</div>
            <div class="home-card-desc">Crawling web. Endpoints estáticos, JS y headless con Chrome.</div>
            <div class="home-card-tag"><span class="tag tag-mit">MIT</span></div>
          </div>
          <div class="home-card" onclick="show('gitleaks',null)">
            <div class="home-card-icon">🔑</div>
            <div class="home-card-name">GitLeaks</div>
            <div class="home-card-desc">Detecta credenciales y secretos en repositorios Git.</div>
            <div class="home-card-tag"><span class="tag tag-mit">MIT</span></div>
          </div>
          <div class="home-card" onclick="show('wayback',null)">
            <div class="home-card-icon">🕰</div>
            <div class="home-card-name">Wayback DL</div>
            <div class="home-card-desc">Descarga histórico de archive.org. El objetivo no recibe tráfico.</div>
            <div class="home-card-tag"><span class="tag tag-mit">MIT</span></div>
          </div>
          <div class="home-card" onclick="show('spiderfoot',null)">
            <div class="home-card-icon">🕸</div>
            <div class="home-card-name">SpiderFoot</div>
            <div class="home-card-desc">200+ módulos OSINT con correlación automática.</div>
            <div class="home-card-tag"><span class="tag tag-gpl">GPL v2</span></div>
          </div>
        </div>
      </div>

      <!-- DISCOVER -->
      <div class="panel" id="panel-discover">
        <div class="page-header">
          <div class="page-title">🔍 Discover <span class="tag tag-mit">MIT</span><span class="tag tag-npsl">Nmap NPSL</span></div>
          <div class="page-desc">Framework orquestador — automatiza recon pasivo y activo en un solo flujo.</div>
        </div>
        <div class="subtool-grid" id="sg-discover"></div>
        <div class="cmd-preview" id="cp-discover"><div class="cmd-label">Comando a ejecutar</div><div class="cmd-code" id="cc-discover"></div></div>
        <div class="actions-row">
          <input class="extra-input" id="args-discover" placeholder="Flags adicionales (opcional)">
          <button class="run-btn" id="run-discover" onclick="runTool('discover')">▶ Ejecutar</button>
          <button class="stop-btn" id="stop-discover" onclick="stopTool('discover')">⬛ Parar</button>
        </div>
        <div class="output-section">
          <div class="output-header">
            <span class="output-title">Resultados</span>
            <div class="output-actions"><button class="clr-btn" onclick="clearOut('discover')">Limpiar</button></div>
          </div>
          <div class="out-tabs">
            <button class="out-tab active" onclick="switchOutTab('discover','parsed',this)">Resumen</button>
            <button class="out-tab" onclick="switchOutTab('discover','raw',this)">Output completo</button>
          </div>
          <div class="out-tab-content active" id="parsed-discover"><div class="results-area" id="results-discover"><p style="color:var(--text3);font-size:.8rem;padding:8px 0">Selecciona una subherramienta y pulsa Ejecutar.</p></div></div>
          <div class="out-tab-content" id="raw-discover"><div class="raw-output" id="raw-out-discover">// Output completo aparecerá aquí</div></div>
          <div class="status-bar">
            <div class="status-running" id="sr-discover"><div class="spinner"></div>Ejecutando...</div>
            <div class="status-done" id="sd-discover">✓ Completado</div>
            <span id="ss-discover" style="color:var(--text3)">Listo</span>
          </div>
        </div>
      </div>

      <!-- AMASS -->
      <div class="panel" id="panel-amass">
        <div class="page-header">
          <div class="page-title">🌐 Amass <span class="tag tag-apache">Apache 2.0</span></div>
          <div class="page-desc">Enumeración avanzada de subdominios con +55 fuentes, grafos de infraestructura y tracking histórico.</div>
        </div>
        <div class="subtool-grid" id="sg-amass"></div>
        <div class="cmd-preview" id="cp-amass"><div class="cmd-label">Comando a ejecutar</div><div class="cmd-code" id="cc-amass"></div></div>
        <div class="actions-row">
          <input class="extra-input" id="args-amass" placeholder="Flags adicionales (ej: -timeout 30)">
          <button class="run-btn" id="run-amass" onclick="runTool('amass')">▶ Ejecutar</button>
          <button class="stop-btn" id="stop-amass" onclick="stopTool('amass')">⬛ Parar</button>
        </div>
        <div class="output-section">
          <div class="output-header"><span class="output-title">Resultados</span><div class="output-actions"><button class="clr-btn" onclick="clearOut('amass')">Limpiar</button></div></div>
          <div class="out-tabs">
            <button class="out-tab active" onclick="switchOutTab('amass','parsed',this)">Resumen</button>
            <button class="out-tab" onclick="switchOutTab('amass','raw',this)">Output completo</button>
          </div>
          <div class="out-tab-content active" id="parsed-amass"><div class="results-area" id="results-amass"><p style="color:var(--text3);font-size:.8rem;padding:8px 0">Selecciona una subherramienta y pulsa Ejecutar.</p></div></div>
          <div class="out-tab-content" id="raw-amass"><div class="raw-output" id="raw-out-amass">// Output completo aparecerá aquí</div></div>
          <div class="status-bar">
            <div class="status-running" id="sr-amass"><div class="spinner"></div>Ejecutando...</div>
            <div class="status-done" id="sd-amass">✓ Completado</div>
            <span id="ss-amass" style="color:var(--text3)">Listo</span>
          </div>
        </div>
      </div>

      <!-- KATANA -->
      <div class="panel" id="panel-katana">
        <div class="page-header">
          <div class="page-title">🕷 Katana <span class="tag tag-mit">MIT</span></div>
          <div class="page-desc">Crawling web — endpoints estáticos y dinámicos con JavaScript.</div>
        </div>
        <div class="subtool-grid" id="sg-katana"></div>
        <div class="cmd-preview" id="cp-katana"><div class="cmd-label">Comando a ejecutar</div><div class="cmd-code" id="cc-katana"></div></div>
        <div class="actions-row">
          <input class="extra-input" id="args-katana" placeholder="Flags adicionales (ej: -depth 3)">
          <button class="run-btn" id="run-katana" onclick="runTool('katana')">▶ Ejecutar</button>
          <button class="stop-btn" id="stop-katana" onclick="stopTool('katana')">⬛ Parar</button>
        </div>
        <div class="output-section">
          <div class="output-header"><span class="output-title">Resultados</span><div class="output-actions"><button class="clr-btn" onclick="clearOut('katana')">Limpiar</button></div></div>
          <div class="out-tabs">
            <button class="out-tab active" onclick="switchOutTab('katana','parsed',this)">Resumen</button>
            <button class="out-tab" onclick="switchOutTab('katana','raw',this)">Output completo</button>
          </div>
          <div class="out-tab-content active" id="parsed-katana"><div class="results-area" id="results-katana"><p style="color:var(--text3);font-size:.8rem;padding:8px 0">Selecciona una subherramienta y pulsa Ejecutar.</p></div></div>
          <div class="out-tab-content" id="raw-katana"><div class="raw-output" id="raw-out-katana">// Output completo aparecerá aquí</div></div>
          <div class="status-bar">
            <div class="status-running" id="sr-katana"><div class="spinner"></div>Ejecutando...</div>
            <div class="status-done" id="sd-katana">✓ Completado</div>
            <span id="ss-katana" style="color:var(--text3)">Listo</span>
          </div>
        </div>
      </div>

      <!-- GITLEAKS -->
      <div class="panel" id="panel-gitleaks">
        <div class="page-header">
          <div class="page-title">🔑 GitLeaks <span class="tag tag-mit">MIT</span></div>
          <div class="page-desc">Detecta credenciales y secretos en repositorios Git. Análisis 100% local.</div>
        </div>
        <div class="subtool-grid" id="sg-gitleaks"></div>
        <div class="cmd-preview" id="cp-gitleaks"><div class="cmd-label">Comando a ejecutar</div><div class="cmd-code" id="cc-gitleaks"></div></div>
        <div class="actions-row">
          <input class="extra-input" id="args-gitleaks" placeholder="Ruta del repo (ej: /opt/repos/objetivo)">
          <button class="run-btn" id="run-gitleaks" onclick="runTool('gitleaks')">▶ Ejecutar</button>
          <button class="stop-btn" id="stop-gitleaks" onclick="stopTool('gitleaks')">⬛ Parar</button>
        </div>
        <div class="output-section">
          <div class="output-header"><span class="output-title">Resultados</span><div class="output-actions"><button class="clr-btn" onclick="clearOut('gitleaks')">Limpiar</button></div></div>
          <div class="out-tabs">
            <button class="out-tab active" onclick="switchOutTab('gitleaks','parsed',this)">Resumen</button>
            <button class="out-tab" onclick="switchOutTab('gitleaks','raw',this)">Output completo</button>
          </div>
          <div class="out-tab-content active" id="parsed-gitleaks"><div class="results-area" id="results-gitleaks"><p style="color:var(--text3);font-size:.8rem;padding:8px 0">Selecciona una subherramienta y pulsa Ejecutar.</p></div></div>
          <div class="out-tab-content" id="raw-gitleaks"><div class="raw-output" id="raw-out-gitleaks">// Output completo aparecerá aquí</div></div>
          <div class="status-bar">
            <div class="status-running" id="sr-gitleaks"><div class="spinner"></div>Ejecutando...</div>
            <div class="status-done" id="sd-gitleaks">✓ Completado</div>
            <span id="ss-gitleaks" style="color:var(--text3)">Listo</span>
          </div>
        </div>
      </div>

      <!-- WAYBACK -->
      <div class="panel" id="panel-wayback">
        <div class="page-header">
          <div class="page-title">🕰 Wayback Downloader <span class="tag tag-mit">MIT</span></div>
          <div class="page-desc">Descarga versiones archivadas desde archive.org. El objetivo nunca recibe tráfico.</div>
        </div>
        <div class="subtool-grid" id="sg-wayback"></div>
        <div class="cmd-preview" id="cp-wayback"><div class="cmd-label">Comando a ejecutar</div><div class="cmd-code" id="cc-wayback"></div></div>
        <div class="actions-row">
          <input class="extra-input" id="args-wayback" placeholder="Flags adicionales (ej: --limit-pages 100)">
          <button class="run-btn" id="run-wayback" onclick="runTool('wayback')">▶ Ejecutar</button>
          <button class="stop-btn" id="stop-wayback" onclick="stopTool('wayback')">⬛ Parar</button>
        </div>
        <div class="output-section">
          <div class="output-header"><span class="output-title">Resultados</span><div class="output-actions"><button class="clr-btn" onclick="clearOut('wayback')">Limpiar</button></div></div>
          <div class="out-tabs">
            <button class="out-tab active" onclick="switchOutTab('wayback','parsed',this)">Resumen</button>
            <button class="out-tab" onclick="switchOutTab('wayback','raw',this)">Output completo</button>
          </div>
          <div class="out-tab-content active" id="parsed-wayback"><div class="results-area" id="results-wayback"><p style="color:var(--text3);font-size:.8rem;padding:8px 0">Selecciona una subherramienta y pulsa Ejecutar.</p></div></div>
          <div class="out-tab-content" id="raw-wayback"><div class="raw-output" id="raw-out-wayback">// Output completo aparecerá aquí</div></div>
          <div class="status-bar">
            <div class="status-running" id="sr-wayback"><div class="spinner"></div>Ejecutando...</div>
            <div class="status-done" id="sd-wayback">✓ Completado</div>
            <span id="ss-wayback" style="color:var(--text3)">Listo</span>
          </div>
